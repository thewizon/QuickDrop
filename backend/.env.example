PORT=5001

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/quickdrop

# JWT
JWT_SECRET=replace_with_a_long_random_secret

# SMTP (any free-tier provider, e.g. Gmail, Mailtrap, Brevo/Sendinblue)
# If left unset, emails are logged to the console instead of sent (safe for local dev)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="QuickDrop <no-reply@quickdrop.com>"
